# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Admin (Server-side only)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Internal API and admin automation
CRON_SECRET=replace_with_long_random_secret
INTERNAL_API_TOKEN=replace_with_long_random_secret
SCRAPER_SECRET=replace_with_long_random_secret
INTERNAL_API_BASE_URL=http://localhost:3000

# GitHub Actions trigger for scraper
GITHUB_TOKEN=ghp_replace_me
GITHUB_REPO=iusmuchandra/jobhunt-ai

# OpenAI (fallback)
OPENAI_API_KEY=sk-...

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@jobhunt.ai

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=JobHunt AI
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# SMTP / notifications
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_PORT=587

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Feature Flags
ENABLE_AI_MATCHING=true
ENABLE_COVER_LETTER_GEN=true
ENABLE_RESUME_ANALYSIS=true

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
